# ========================
# SECURITY — NEVER COMMIT
# ========================
.env
.env.local
.env.*.local
.env.production
secrets.js
secrets.json
*.pem
*.p12
*.p8
*.jks
*.mobileprovision
*.keystore
google-services.json
GoogleService-Info.plist

# ========================
# NODE / NPM
# ========================
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*
package-lock.json.bak

# ========================
# EXPO
# ========================
.expo/
dist/
web-build/
expo-env.d.ts
.expo-shared/

# ========================
# METRO
# ========================
.metro-health-check*

# ========================
# NATIVE BUILD ARTIFACTS
# ========================
/ios
/android
.kotlin/
*.orig.*

# ========================
# OS FILES
# ========================
.DS_Store
Thumbs.db
*.pem
.vscode/settings.json

# ========================
# TYPESCRIPT
# ========================
*.tsbuildinfo

# ========================
# LOGS
# ========================
logs/
*.log

# ========================
# VIRTUAL ENVIRONMENT
# ========================
.venv/
venv/
env/
__pycache__/
*.pyc
