# ============================================================
# Sumbandila App — Environment Variables Template
# ============================================================
# COPY this file to .env and fill in your real values.
# NEVER commit .env to git — it is in .gitignore.
# ============================================================

# --- Backend API ---
API_BASE_URL=https://api.sumbandila.co.za/v1
API_TIMEOUT_MS=10000

# --- Verification Microservice ---
VERIFICATION_API_KEY=your_verification_api_key_here
HPCSA_API_KEY=your_hpcsa_key_here
LPC_API_KEY=your_lpc_key_here
SAQA_API_KEY=your_saqa_key_here
CIPC_API_KEY=your_cipc_key_here

# --- Authentication (Auth0 / Firebase) ---
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id

# --- Payments (PayFast / Peach Payments) ---
PAYFAST_MERCHANT_ID=your_payfast_merchant_id
PAYFAST_MERCHANT_KEY=your_payfast_merchant_key
PAYFAST_PASSPHRASE=your_payfast_passphrase
PEACH_ENTITY_ID=your_peach_entity_id
PEACH_ACCESS_TOKEN=your_peach_access_token

# --- AI Assistant ---
OPENAI_API_KEY=your_openai_key_here
AI_ASSISTANT_MODEL=gpt-4o-mini

# --- Analytics ---
SENTRY_DSN=your_sentry_dsn_here
MIXPANEL_TOKEN=your_mixpanel_token_here

# --- Storage ---
AWS_S3_BUCKET=sumbandila-verified-docs
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# --- Push Notifications ---
EXPO_PUSH_TOKEN=your_expo_push_token
FCM_SERVER_KEY=your_fcm_server_key

# --- App Config ---
APP_ENV=development
DEBUG_MODE=true
