{
  "expo": {
    "name": "Sumbandila Pro",
    "slug": "sumbandila-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raphasha27.sumbandila",
      "infoPlist": {
        "NSCameraUsageDescription": "Sumbandila needs camera access to scan QR codes on certificates.",
        "NSPhotoLibraryUsageDescription": "Sumbandila needs photo library access to scan certificates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0A2463"
      },
      "package": "com.raphasha27.sumbandila",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Sumbandila to access your camera to scan QR codes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "sumbandila-sdm-2026"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/sumbandila-sdm-2026"
    }
  }
}
